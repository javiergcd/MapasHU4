{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "outDir": "./dist",

    "allowImportingTsExtensions": false
  },
  "include": ["src", "api"],
  "exclude": ["node_modules"]
}
